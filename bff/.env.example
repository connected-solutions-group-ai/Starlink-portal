# ─────────────────────────────────────────────────────────────
# CSG Sales Portal BFF — environment
# Copy to `.env` and fill in. NEVER commit `.env` or the private key.
# ─────────────────────────────────────────────────────────────

# Your NetSuite account id, lowercase, dashes not underscores (e.g. 1234567 or 1234567-sb1 for a sandbox)
NS_ACCOUNT_ID=1234567-sb1

# OAuth 2.0 client credentials (M2M) — from Setup > Integration > Manage Integrations
# and the mapping created under Setup > Integration > OAuth 2.0 Client Credentials (M2M) Setup.
NS_CLIENT_ID=your_consumer_key_client_id

# The Certificate ID shown after you upload your public certificate in the M2M mapping screen.
NS_CERTIFICATE_ID=your_certificate_id_kid

# Path to the PRIVATE key that matches the uploaded certificate (PEM). Keep this file out of git.
NS_PRIVATE_KEY_PATH=./secrets/private_key.pem
# ...or inline the PEM instead of a path (escape newlines as \n). Leave blank if using the path above.
NS_PRIVATE_KEY=

# JWT signing algorithm registered with the certificate: PS256 (recommended) or RS256 / ES256.
NS_JWT_ALG=PS256

# Scopes granted to the integration. rest_webservices covers record + SuiteQL.
NS_SCOPE=rest_webservices

# Default customer to attach new orders to until account→customer mapping is implemented (internal id).
NS_DEFAULT_CUSTOMER_ID=

# Server
PORT=8787
# CORS: the origin the portal is served from. Use * only for local dev.
ALLOW_ORIGIN=http://localhost:8787

# Safety: when true, /api/orders maps the payload and returns the NetSuite body WITHOUT writing.
# Start here, confirm the mapping in NetSuite's REST API browser, then set to false.
DRY_RUN=true

# ─────────── DocuSign (eSignature, JWT Grant) ───────────
DS_INTEGRATION_KEY=your_integration_key_guid
DS_USER_ID=api_user_guid_to_impersonate
DS_ACCOUNT_ID=your_api_account_id_guid
# Demo: https://account-d.docusign.com  +  https://demo.docusign.net/restapi
# Prod: https://account.docusign.com    +  the baseUri returned by /oauth/userinfo
DS_OAUTH_BASE=https://account-d.docusign.com
DS_BASE_URI=https://demo.docusign.net/restapi
DS_PRIVATE_KEY_PATH=./secrets/docusign_private.pem
DS_PRIVATE_KEY=
# Template IDs for the standard documents (from DocuSign > Templates)
DS_TEMPLATE_SOW=
DS_TEMPLATE_BIGLEAF=
DS_TEMPLATE_MSA=

# ─────────── Field service dispatch (Bolt Squad) ───────────
# Where a booking is POSTed (Zapier/Make hook, internal endpoint, Teams/Slack webhook...).
# Leave blank to record bookings without dispatching.
FS_WEBHOOK_URL=

# ─────────── Google Maps (front-end) ───────────
# The portal uses a keyless satellite embed by default. For the official Embed API,
# set GMAPS_KEY in index.html (top of the <script>), not here — the key is a browser key.

